# Mantle Network Configuration
VITE_MANTLE_CHAIN_ID=5003
VITE_MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz

# Deployer Mnemonics (for contract deployment - NEVER commit this!)
DEPLOYER_MNEMONIC_ARB=your_mnemonic_here
DEPLOYER_MNEMONIC_BASE=your_mnemonic_here

# Privy (Embedded Wallets)
VITE_PRIVY_APP_ID=your_privy_app_id
VITE_PAYMENT_PRIVY_APP_ID=your_payment_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# Reclaim Protocol (Optional - for zkTLS proofs)
VITE_RECLAIM_APP_ID=your_reclaim_app_id
VITE_RECLAIM_APP_SECRET=your_reclaim_app_secret

# Contract Addresses - Arbitrum Mainnet (42161)
VITE_DEMO_USDC_ADDRESS=0xaf88d065e77c8cc2239327c5edb3a432268e5831
VITE_INVOICE_NFT_ADDRESS=your_invoice_nft_address
VITE_INVOICE_REGISTRY_ADDRESS=your_invoice_registry_address
VITE_USMT_PLUS_ADDRESS=your_usmt_plus_address
VITE_VAULT_ADDRESS=your_vault_address
VITE_STAKING_ADDRESS=your_staking_address
VITE_ADVANCE_ENGINE_ADDRESS=your_advance_engine_address
VITE_REPUTATION_ADDRESS=your_reputation_address
VITE_SETTLEMENT_ROUTER_ADDRESS=your_settlement_router_address

# Supabase (notifications, contacts, invoice metadata)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Mantle Etherscan API Key (for contract verification)
MANTLE_ETHERSCAN_API_KEY=your_etherscan_api_key

# Private Payments (RAILGUN integration)
# Set to "true" to enable the Private Pay feature (shield/unshield/private send)
VITE_PRIVATE_PAYMENTS_ENABLED=true
VITE_DEFAULT_CHAIN_ID=42161
# RPC URL for Arbitrum Mainnet
VITE_RPC_URL_42161=https://arbitrum-one-rpc.publicnode.com
